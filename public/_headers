# HTML entry — never cache, so a new deploy instantly invalidates
# previously-cached HTML pointing at stale asset hashes.
/index.html
  Cache-Control: public, max-age=0, must-revalidate
  X-Content-Type-Options: nosniff

# Long-cache hashed Vite assets (filenames already include content hashes)
/assets/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

# Static images served from /public — moderate caching, no fingerprint
/og-image.png
  Cache-Control: public, max-age=2592000
/og-image.svg
  Cache-Control: public, max-age=2592000
/favicon.ico
  Cache-Control: public, max-age=86400
/favicon.png
  Cache-Control: public, max-age=86400
/placeholder.svg
  Cache-Control: public, max-age=86400

# SEO discovery files — short cache so updates propagate quickly
/sitemap.xml
  Cache-Control: public, max-age=3600
/robots.txt
  Cache-Control: public, max-age=3600
/llms.txt
  Cache-Control: public, max-age=3600
/site.webmanifest
  Cache-Control: public, max-age=86400

# Defaults for everything else (HTML included): basic security hardening
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
